# D7pay Jenkins 发布参数示例。
# 真实密钥从 Jenkins Credentials / K8s Secret 注入，不提交到 Git。

TENANT_CODE=d7pay
KUBE_NAMESPACE=pk-d7pay
RUN_ENV=PROD
KUBECONFIG=/etc/kubernetes/admin.conf
BUSINESS_TIMEZONE=UTC
APP_DISPLAY_TIMEZONE=Asia/Karachi

ADMIN_H5_BUILD_SCRIPT=d7pay:prod
MERCHANT_H5_BUILD_SCRIPT=d7pay:prod
APKDOWNLOAD_BUILD_SCRIPT=build:d7pay

API_IMAGE=registry.example.com/pk/api:d7pay-${BUILD_NUMBER}
ADMIN_IMAGE=registry.example.com/pk/admin:d7pay-${BUILD_NUMBER}
MERCHANT_IMAGE=registry.example.com/pk/merchant:d7pay-${BUILD_NUMBER}
ADMIN_H5_IMAGE=registry.example.com/pk/admin-h5:d7pay-${BUILD_NUMBER}
MERCHANT_H5_IMAGE=registry.example.com/pk/merchant-h5:d7pay-${BUILD_NUMBER}
APKDOWNLOAD_IMAGE=registry.example.com/pk/apkdownload:d7pay-${BUILD_NUMBER}

MYSQL_HOST=mysql
MYSQL_DATABASE=pakistan_d7pay
MYSQL_USER=d7pay_app
REDIS_HOST=redis

# 这些是占位域名。Jenkins 正式发布前必须替换为 D7pay 客户自有域名。
# D7pay 配置检查脚本会拒绝 example.com 和 awekay.com，避免误把 D7pay 接到我们的域名。
API_DOMAIN=api.d7pay.example.com
ADMIN_DOMAIN=admin.d7pay.example.com
MERCHANT_DOMAIN=merchant.d7pay.example.com
APKDOWNLOAD_DOMAIN=apkdownload.d7pay.example.com
API_PUBLIC_SCHEME=http

API_PUBLIC_NODEPORT=31085
ADMIN_H5_NODEPORT=31081
MERCHANT_H5_NODEPORT=31082
APKDOWNLOAD_NODEPORT=31080

# D7pay 配置应用脚本会用 API_PUBLIC_SCHEME + API_DOMAIN 渲染下面三个运行时值。
API_PAY_URL=http://api.d7pay.example.com/api/order/
API_OSPAY_API_HOST=http://api.d7pay.example.com/api
API_WEBSOCKET_ALLOW_HOST=api.d7pay.example.com
ADMIN_API_URL=http://api:9000
MERCHANT_API_URL=http://api:9000

APP_DISPLAY_NAME=D7pay Merchant
APP_SHORT_NAME=D7pay
APP_APPLICATION_ID=com.d7pay.merchant
APP_ICON=@mipmap/ic_launcher_d7pay
APP_API_BASE_URL=http://api.d7pay.example.com
APP_APK_KEY=d7pay_merchant
APP_SIGNING_MODE=shared_release_keystore
ANDROID_KEY_PROPERTIES_SECRET=d7pay-android-signing
REQUIRE_RELEASE_SIGNING=true
FLUTTER_APP_DIR=/opt/cicd/k8s/ashrafi_merchant_flutter
FLUTTER_BIN=/opt/flutter/bin/flutter

FINGERPRINT_HOST_PATH=/data/pk-d7pay/fingerprint
APKDOWNLOAD_HOST_PATH=/data/pk-d7pay/apkdownload/d7pay

PROJECT_DIR=/opt/cicd/k8s_d7pay/pk_project_k8s
K8S_ROOT=/opt/cicd/k8s
REGISTRY=10.170.0.18:30086/lib
D7PAY_GIT_BRANCH=d7pay
D7PAY_RUNTIME_SECRET_YAML=/opt/cicd/secrets/d7pay-runtime-secret.yaml
