API_COOKIE_SECRET=generate-with-secrets-token-hex-32
MERCHANT_DEMO_MC_KEY=generate-with-secrets-token-hex-16
ADMIN_INITIAL_PASSWORD=generate-and-store-in-handover
MERCHANT_INITIAL_PASSWORD=generate-and-store-in-handover
PARTNER_INITIAL_PASSWORD=generate-and-store-in-handover
