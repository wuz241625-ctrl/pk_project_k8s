# D7pay 托管实例密钥模板。
# 真实值由部署脚本在线生成并写入 K8s Secret，不提交到 Git。

TENANT_CODE=d7pay
MYSQL_DATABASE=pakistan_d7pay
MYSQL_USER=d7pay_app
MYSQL_PASSWORD=generate-with-secrets-token-hex-32
